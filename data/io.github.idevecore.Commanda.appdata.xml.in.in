<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Commanda</name>
  <summary></summary>
  <description>
    <p></p>
  </description>

  <developer id="tld.vendor">
    <name>Ideve Core</name>
  </developer>

  <launchable type="desktop-id">@app-id@.desktop</launchable>
  <url type="homepage">https://github.com/ideveCore/commanda</url>
  <url type="bugtracker">https://github.com/ideveCore/commanda/issues</url>
  <url type="vcs-browser">https://github.com/ideveCore/commanda</url>
  <url type="translate">https://hosted.weblate.org/engage/commanda/</url>
  <url type="contribute">https://github.com/ideveCore/commanda</url>

  <translation type="gettext">commanda</translation>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <caption>Main screen of the app</caption>
      <image type="source">
        https://raw.githubusercontent.com/ideveCore/commanda/main/data/screenshots/01.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.0" date="2026-04-19">
      <url type="details">https://github.com/ideveCore/commanda</url>
      <description translate="no">
        <p>Currency Converter 1.0.0: Application launch</p>
      </description>
    </release>
  </releases>

</component>